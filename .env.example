# =============================================================
# Property Insights Australia — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================

# --- AI / LLM ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pia
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# --- Scraping ---
ZENROWS_API_KEY=your-zenrows-api-key
SCRAPE_INTERVAL_MINUTES=30
MAX_CONCURRENT_SCRAPERS=5
USER_AGENT=PropertyInsightsAU/1.0

# --- Notifications ---
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+61400000000
SENDGRID_API_KEY=your-sendgrid-key
FROM_EMAIL=alerts@propertyinsightsaustralia.com.au

# --- Application ---
APP_NAME=Property Insights Australia
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
SECRET_KEY=change-this-to-a-random-secret-key

# --- Australian Market Config ---
DEFAULT_INTEREST_RATE=6.25
DEFAULT_LOAN_LVR=80
STAMP_DUTY_STATE=NSW
COUNCIL_RATE_ESTIMATE_PCT=0.3

# --- Scoring Thresholds ---
BARGAIN_SCORE_MIN=65
GOLDEN_OPPORTUNITY_SCORE=85
DISTRESS_DELTA_THRESHOLD=15
MIN_NET_YIELD=5.0
MIN_ROI=12.0

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# --- Redis (for Celery) ---
REDIS_URL=redis://localhost:6379/0
